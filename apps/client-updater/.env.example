# API base URL (defaults to /api if not set)
VITE_API_BASE_URL=/api

# Consumer ID sent in X-Consumer-Id header on every API call
VITE_CONSUMER_ID=client-updater

# Use mock data instead of real API calls (default: true)
VITE_USE_MOCKS=true

# Mock role for local development: 'advisor' or 'support_staff'
VITE_MOCK_ROLE=advisor

# Set to 'true' to skip artificial delays in mock services
VITE_SKIP_DELAYS=false
