# 12-factor app config — copy to .env.local and fill in your values
# Never commit .env.local to source control

# Base URL for the client API backend
VITE_API_BASE_URL=https://api.your-domain.com

# Consumer ID sent in X-Consumer-Id header on every API call
VITE_CONSUMER_ID=client-updater

# Use mock data instead of real API calls (default: true)
# Set to 'false' to hit the real backend
VITE_USE_MOCKS=true

# Mock the signed-on user role for local development
# Values: 'advisor' (default) | 'support_staff'
VITE_MOCK_ROLE=advisor

# (Optional) App-level feature flags
# VITE_ENABLE_DEEPLINK=true
